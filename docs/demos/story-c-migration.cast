[19.8, "o", "\u001b[1;36m  \u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501 The Quantum Migration Roadmap \u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u001b[0m\r\n"]
[20.1, "o", "\u001b[0;90m  QuantumNexum Labs \u2014 PKI Infrastructure Review\u001b[0m\r\n"]
[20.3, "o", "\u001b[0;90m  Presented by: Certificate Operations Team\u001b[0m\r\n"]
[20.5, "o", "\r\n"]
[20.8, "o", "\u001b[1;37m  Three phases. One goal. Quantum-safe PKI.\u001b[0m\r\n"]
[21.1, "o", "\r\n"]
[21.4, "o", "\u001b[0;90m  \u250c\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2510  \u2500\u2500\u2500\u2500\u25ba  \u250c\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2510  \u2500\u2500\u2500\u2500\u25ba  \u250c\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2510\u001b[0m\r\n"]
[21.6, "o", "\u001b[0;90m  \u2502  Phase 1: Classical  \u2502  \u2500\u2500\u2500\u2500\u25ba  \u2502   Phase 2: Hybrid   \u2502  \u2500\u2500\u2500\u2500\u25ba  \u2502 Phase 3: Post-Quantum \u2502\u001b[0m\r\n"]
[21.8, "o", "\u001b[0;90m  \u2514\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2518         \u2514\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2518         \u2514\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2518\u001b[0m\r\n"]
[22.0, "o", "\u001b[31m       MD5+RSA-1024                \u001b[0m\u001b[33m   SHA-384+ECDSA+P384           \u001b[0m\u001b[32m   ML-DSA-87\u001b[0m\r\n"]
[22.2, "o", "\u001b[31m       COMPLETED               \u001b[0m\u001b[33m   IN PROGRESS              \u001b[0m\u001b[32m   DEPLOYED\u001b[0m\r\n"]
[22.3, "o", "\r\n"]
