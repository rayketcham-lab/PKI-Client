[70.0, "o", "\u001b[1;36m  \u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501 Migration Status \u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u001b[0m\r\n"]
[70.2, "o", "\r\n"]
[70.4, "o", "\u001b[0;90m  Phase 1 (Classical):    \u001b[0m\u001b[31m\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u001b[0m  \u001b[31mCOMPLETE\u001b[0m\r\n"]
[70.8, "o", "\u001b[0;90m  Phase 2 (Hybrid):       \u001b[0m\u001b[33m\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2591\u2591\u001b[0m  \u001b[33m92% \u2014 23 days to renewal\u001b[0m\r\n"]
[71.2, "o", "\u001b[0;90m  Phase 3 (Post-Quantum): \u001b[0m\u001b[32m\u2588\u2588\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u001b[0m  \u001b[32mDEPLOYED \u2014 3602 days\u001b[0m\r\n"]
[71.6, "o", "\r\n"]
[71.9, "o", "\r\n"]
[72.2, "o", "\u001b[1;37m  Built with:\u001b[0m\r\n"]
[72.4, "o", "\r\n"]
[72.6, "o", "\u001b[1;36m  \u25b8 PKI-Client\u001b[0m\u001b[0;90m \u2014 19 commands for cert inspection, TLS probing, DANE, diff\u001b[0m\r\n"]
[72.8, "o", "\u001b[0;90m    Pure Rust \u00b7 One binary \u00b7 Post-quantum native\u001b[0m\r\n"]
[73.0, "o", "\r\n"]
[73.2, "o", "\u001b[1;36m  \u25b8 PKI-Signing-Service\u001b[0m\u001b[0;90m \u2014 code signing across RSA, ECDSA, ML-DSA, SLH-DSA\u001b[0m\r\n"]
[73.4, "o", "\u001b[0;90m    Multi-algorithm \u00b7 Audit logging \u00b7 API-first\u001b[0m\r\n"]
[73.6, "o", "\r\n"]
[73.8, "o", "\u001b[1;36m  \u25b8 PKI-CA-Engine\u001b[0m\u001b[0;90m \u2014 declarative CA hierarchy builder\u001b[0m\r\n"]
[74.0, "o", "\u001b[0;90m    Automated lifecycle \u00b7 Certificate policies \u00b7 FIPS 140-3 ready\u001b[0m\r\n"]
