[5.1, "o", "  \u001b[1;33m\ud83c\udf2e\u001b[0m \u001b[1;37mTACOO TUESDAY: Operation Quantum Salsa\u001b[0m \u001b[1;33m\ud83c\udf2e\u001b[0m\r\n"]
[5.4, "o", "\r\n"]
[5.4, "o", "  \u001b[2;36mMcKinney, Texas \u2014 Where tacos meet lattice-based cryptography\u001b[0m\r\n"]
[5.4, "o", "  \u001b[2;36m\"Your burritos are safe. Quantum computers can't touch these.\"\u001b[0m\r\n"]
[5.7, "o", "\r\n"]
[5.7, "o", "  \u001b[2;36mWhat happens when a taco shop decides RSA isn't good enough?\u001b[0m\r\n"]
[5.7, "o", "  \u001b[2;36mThey call QuantumNexum. And they go full ML-DSA.\u001b[0m\r\n"]
[5.7, "o", "  \u001b[2;36mNo half measures. No hybrid. Pure post-quantum. Let's go.\u001b[0m\r\n"]
