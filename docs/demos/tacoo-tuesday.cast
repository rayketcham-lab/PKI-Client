[0.5, "o", "  \u001b[1;37mBut Taco Bueno is very real.\u001b[0m\r\n"]
[0.8, "o", "\r\n"]
[0.8, "o", "  \u001b[1;32m\ud83c\udf2e  It's Taco Tuesday \u2014 March 24, 2026\u001b[0m\r\n"]
[0.8, "o", "  \u001b[1;32m\ud83c\udf2e  Go visit your local Taco Bueno\u001b[0m\r\n"]
[0.8, "o", "  \u001b[1;32m\ud83c\udf2e  Redeem your FREE taco\u001b[0m\r\n"]
