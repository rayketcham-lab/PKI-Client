[69.05, "o", "\u001b[0;90m  Connecting to quantumnexum.com:443...\u001b[0m\r\n"]
[69.85, "o", "\u001b[1;37m\u250f\u2501\u2501 TLS Probe \u2014 quantumnexum.com:443 \u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2513\u001b[0m\r\n"]
[70.05, "o", "\u001b[1;37m\u2503\u001b[0m \u001b[1mProtocol\u001b[0m         \u001b[32mTLSv1.3\u001b[0m                                                                              \u001b[1;37m\u2503\u001b[0m\r\n"]
[70.25, "o", "\u001b[1;37m\u2503\u001b[0m \u001b[1mCipher\u001b[0m           TLS_AES_256_GCM_SHA384                                                                \u001b[1;37m\u2503\u001b[0m\r\n"]
[70.45, "o", "\u001b[1;37m\u2503\u001b[0m \u001b[1mSNI\u001b[0m              quantumnexum.com                                                                      \u001b[1;37m\u2503\u001b[0m\r\n"]
[70.65, "o", "\u001b[1;37m\u2503\u001b[0m \u001b[1mCert Subject\u001b[0m     CN=quantumnexum.com, O=QuantumNexum Inc, C=US                                         \u001b[1;37m\u2503\u001b[0m\r\n"]
[70.85, "o", "\u001b[1;37m\u2503\u001b[0m \u001b[1mIssued By\u001b[0m        CN=QuantumNexum Hybrid Intermediate CA                                                 \u001b[1;37m\u2503\u001b[0m\r\n"]
[71.05, "o", "\u001b[1;37m\u2503\u001b[0m \u001b[1mNot After\u001b[0m        \u001b[32m2026-04-22 00:00:00 UTC \u2190 30 days remaining\u001b[0m                                        \u001b[1;37m\u2503\u001b[0m\r\n"]
[71.25, "o", "\u001b[1;37m\u2503\u001b[0m \u001b[1mSANs\u001b[0m             quantumnexum.com, www.quantumnexum.com, api.quantumnexum.com                           \u001b[1;37m\u2503\u001b[0m\r\n"]
[71.45, "o", "\u001b[1;37m\u2503\u001b[0m \u001b[1mChain\u001b[0m            Leaf \u2192 Intermediate \u2192 Hybrid Root (3 certs)                                           \u001b[1;37m\u2503\u001b[0m\r\n"]
[71.65, "o", "\u001b[1;37m\u2503\u001b[0m \u001b[1mChain Valid\u001b[0m      \u001b[32mYES\u001b[0m                                                                                   \u001b[1;37m\u2503\u001b[0m\r\n"]
[71.85, "o", "\u001b[1;37m\u2503\u001b[0m \u001b[1mOCSP Stapled\u001b[0m     \u001b[32mYES\u001b[0m  (good)                                                                        \u001b[1;37m\u2503\u001b[0m\r\n"]
[72.05, "o", "\u001b[1;37m\u2503\u001b[0m                                                                                                    \u001b[1;37m\u2503\u001b[0m\r\n"]
[72.25, "o", "\u001b[1;37m\u2503\u001b[0m \u001b[32m\u2714 TLS HEALTHY\u001b[0m  Production endpoint is up and serving valid certificates                             \u001b[1;37m\u2503\u001b[0m\r\n"]
[72.45, "o", "\u001b[1;37m\u2517\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u251b\u001b[0m\r\n"]
[72.65, "o", "\r\n"]
[72.85, "o", "\u001b[0;90m  # TLS 1.3 active. Production is up. The expired cert is legacy \u2014 not serving.\u001b[0m\r\n"]
[75.15, "o", "\r\n\r\n"]
[75.65, "o", "\u001b[1;36m\u2501\u2501\u2501 Incident Resolved \u2501\u2501\u2501\u001b[0m\r\n"]
[76.15, "o", "\r\n"]
[76.45, "o", "\u001b[1;37m  Root cause:\u001b[0m \u001b[0mLegacy RSA-4096 CA cert expired but not decommissioned.\u001b[0m\r\n"]
[77.05, "o", "\u001b[1;37m  Impact:    \u001b[0m \u001b[32mMonitoring false positive. Production unaffected.\u001b[0m\r\n"]
[77.65, "o", "\u001b[1;37m  Action:    \u001b[0m \u001b[33mRemove expired cert, schedule hybrid renewal in 23 days.\u001b[0m\r\n"]
[78.45, "o", "\r\n"]
[78.85, "o", "\u001b[0;90m  \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u001b[0m\r\n"]
[79.45, "o", "\r\n"]
[79.85, "o", "\u001b[1;36m  \u25b8 PKI-Client\u001b[0m \u2014 triage in minutes, not hours\r\n"]
[80.45, "o", "\u001b[0;90m    19 commands \u00b7 One binary \u00b7 Post-quantum native\u001b[0m\r\n"]
[81.15, "o", "\r\n"]
[81.55, "o", "\u001b[1;36m  \u25b8 PKI-Signing-Service\u001b[0m \u2014 sign with ML-DSA, SLH-DSA, ECDSA, RSA\r\n"]
[82.15, "o", "\u001b[0;90m    Multi-algorithm \u00b7 Audit logging \u00b7 API-first\u001b[0m\r\n"]
[82.85, "o", "\r\n"]
[83.25, "o", "\u001b[1;36m  \u25b8 PKI-CA-Engine\u001b[0m \u2014 automate cert lifecycle so this doesn't happen again\r\n"]
