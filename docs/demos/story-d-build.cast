[61.95, "o", "\u001b[3;4H\u001b[1;36m\u2501\u2501\u2501 From Zero to Full PKI \u2501\u2501\u2501\u001b[0m"]
[62.25, "o", "\u001b[5;4H\u001b[1;37m20 lines of TOML. One build command.\u001b[0m"]
[62.55, "o", "\u001b[6;4H\u001b[1;37mRoot CA + Issuing CA. Post-quantum. Done.\u001b[0m"]
