[1.5, "o", "  \u001b[0;90m1996\u001b[0m  \u001b[0;90mMD5 + RSA-512\u001b[0m                    \u001b[2;37mseemed fine at the time\u001b[0m\r\n"]
[1.85, "o", "  \u001b[0;90m2004\u001b[0m  \u001b[0;90mSHA-1 + RSA-1024\u001b[0m                 \u001b[2;37malso seemed fine\u001b[0m\r\n"]
[2.2, "o", "  \u001b[0;33m2017\u001b[0m  \u001b[0;33mSHA-256 + RSA-2048\u001b[0m               \u001b[2;37mfine for now\u001b[0m\r\n"]
