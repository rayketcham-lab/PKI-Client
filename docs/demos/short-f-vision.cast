[2.9, "o", "  \u001b[1;36m2026\u001b[0m  \u001b[1;36mML-DSA-87\u001b[0m                        \u001b[2;37mquantum-safe\u001b[0m\r\n"]
[3.25, "o", "  \u001b[1;35m2050\u001b[0m  \u001b[1;35m???\u001b[0m                              \u001b[2;37mwe'll be ready\u001b[0m\r\n"]
[3.9, "o", "\r\n"]
[3.98, "o", "\u001b[1;37m  every era said \"this is fine.\"\u001b[0m\r\n"]
[4.36, "o", "\u001b[1;37m  we're the first ones building the exit.\u001b[0m\r\n"]
