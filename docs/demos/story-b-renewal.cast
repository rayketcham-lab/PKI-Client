[95.7, "o", "\u001b[2J\u001b[1;1H"]
[95.8, "o", "\u001b[1;36m\u2501\u2501\u2501 Renewal Workflow Complete \u2501\u2501\u2501\u001b[0m\r\n"]
[96.0, "o", "\r\n"]
[96.3, "o", "  1. Monitor caught the expiry     \u001b[0;90mpki cert expires --within 30d\u001b[0m\r\n"]
[96.6, "o", "  2. Inspected the expiring cert   \u001b[0;90mpki show --lint\u001b[0m\r\n"]
[96.9, "o", "  3. Generated fresh key           \u001b[0;90mpki key gen ec --curve p384\u001b[0m\r\n"]
[97.2, "o", "  4. Created CSR with SANs         \u001b[0;90mpki csr create\u001b[0m\r\n"]
[97.5, "o", "  5. Verified the CSR              \u001b[0;90mpki csr show\u001b[0m\r\n"]
[97.8, "o", "  6. Compared old vs new           \u001b[0;90mpki diff\u001b[0m\r\n"]
[98.1, "o", "  7. Confirmed production live     \u001b[0;90mpki probe\u001b[0m\r\n"]
[98.4, "o", "\r\n"]
[98.7, "o", "\u001b[0;90m  Submit the CSR to your CA. Deploy the new cert. Done.\u001b[0m\r\n"]
[99.2, "o", "\r\n"]
[99.7, "o", "\u001b[0;90m  \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u001b[0m\r\n"]
[100.1, "o", "\r\n"]
[100.5, "o", "  \u25b8 \u001b[1mPKI-Client\u001b[0m \u2014 the tool you just watched. 19 commands. One binary.\r\n"]
[100.8, "o", "    Pure Rust \u00b7 ACME, EST, SCEP \u00b7 Post-quantum native\r\n"]
[101.2, "o", "\r\n"]
[101.6, "o", "  \u25b8 \u001b[1mPKI-Signing-Service\u001b[0m \u2014 sign code and documents across algorithms\r\n"]
[101.9, "o", "    Multi-algorithm \u00b7 Audit logging \u00b7 REST API\r\n"]
[102.3, "o", "\r\n"]
[102.7, "o", "  \u25b8 \u001b[1mPKI-CA-Engine\u001b[0m \u2014 automate this entire workflow\r\n"]
[103.0, "o", "    Declarative \u00b7 Auto-renewal \u00b7 Policy enforcement\r\n"]
