[77.2, "o", "\u001b[2m  Key:      \u001b[0m RSA 4096-bit \u2192 ML-DSA-87\u001b[31m  \u2717 DIFFERS\u001b[0m\r\n"]
[77.4, "o", "\u001b[2m  Signature:\u001b[0m sha256WithRSAEncryption \u2192 ML-DSA-87\u001b[31m  \u2717 DIFFERS\u001b[0m\r\n"]
[79.4, "o", "\r\n"]
[80.3, "o", "\r\n"]
[81.3, "o", "\u001b[2J\u001b[1;1H"]
[81.8, "o", "\r\n"]
[81.9, "o", "\r\n"]
[82.0, "o", "\r\n"]
[82.1, "o", "\u001b[1;36m  \u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501 The Road Ahead \u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u001b[0m\r\n"]
[82.5, "o", "\u001b[2m  The next quarter-century of cryptographic evolution.\u001b[0m\r\n"]
[84.5, "o", "\r\n"]
[84.8, "o", "\r\n"]
[85.1, "o", "\u001b[33m  \u250f\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2513\u001b[0m\r\n"]
[85.3, "o", "\u001b[33m  \u2503\u001b[0m\u001b[1;33m  2035: The Mandate\u001b[0m\u001b[33m                                                   \u2503\u001b[0m\r\n"]
[85.5, "o", "\u001b[33m  \u2503\u001b[0m\u001b[33m  NSA CNSA 2.0 deadline \u2014 all federal systems post-quantum.        \u2503\u001b[0m\r\n"]
[85.7, "o", "\u001b[33m  \u2503\u001b[0m\u001b[33m  Classical algorithms banned for new certificate issuance.         \u2503\u001b[0m\r\n"]
[85.9, "o", "\u001b[33m  \u2503\u001b[0m\u001b[33m  Every CA must support ML-DSA, ML-KEM, or SLH-DSA.                \u2503\u001b[0m\r\n"]
[86.1, "o", "\u001b[33m  \u2503\u001b[0m\u001b[33m                                                                     \u2503\u001b[0m\r\n"]
[86.3, "o", "\u001b[33m  \u2503\u001b[0m\u001b[2m  If you\u2019re not PQC by now, you\u2019re non-compliant.\u001b[0m\u001b[33m                    \u2503\u001b[0m\r\n"]
[86.5, "o", "\u001b[33m  \u2517\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u251b\u001b[0m\r\n"]
[89.5, "o", "\r\n"]
[89.8, "o", "\r\n"]
[90.1, "o", "\u001b[36m  \u250f\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2513\u001b[0m\r\n"]
[90.3, "o", "\u001b[36m  \u2503\u001b[0m\u001b[1;36m  2040: The Hybrid Sunset\u001b[0m\u001b[36m                                             \u2503\u001b[0m\r\n"]
[90.5, "o", "\u001b[36m  \u2503\u001b[0m\u001b[36m  Composite signatures deprecated \u2014 pure PQC only.                 \u2503\u001b[0m\r\n"]
[90.7, "o", "\u001b[36m  \u2503\u001b[0m\u001b[36m  Automated certificate lifecycle is the norm.                      \u2503\u001b[0m\r\n"]
[90.9, "o", "\u001b[36m  \u2503\u001b[0m\u001b[36m  Manual renewal is a compliance violation.                         \u2503\u001b[0m\r\n"]
[91.1, "o", "\u001b[36m  \u2503\u001b[0m\u001b[36m  Zero-touch issuance. Zero-touch revocation.                       \u2503\u001b[0m\r\n"]
[91.3, "o", "\u001b[36m  \u2503\u001b[0m\u001b[36m                                                                     \u2503\u001b[0m\r\n"]
[91.5, "o", "\u001b[36m  \u2503\u001b[0m\u001b[2m  The transition is over. Classical crypto is history.\u001b[0m\u001b[36m              \u2503\u001b[0m\r\n"]
[91.7, "o", "\u001b[36m  \u2517\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u251b\u001b[0m\r\n"]
[94.7, "o", "\r\n"]
[95.0, "o", "\r\n"]
[95.3, "o", "\u001b[1;35m  \u250f\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2513\u001b[0m\r\n"]
[95.5, "o", "\u001b[1;35m  \u2503\u001b[0m\u001b[1;35m  2045: Zero-Trust PKI\u001b[0m\u001b[1;35m                                                \u2503\u001b[0m\r\n"]
[95.7, "o", "\u001b[1;35m  \u2503\u001b[0m\u001b[35m  Hardware attestation + PQC replaces static certificates.         \u2503\u001b[0m\r\n"]
[95.9, "o", "\u001b[1;35m  \u2503\u001b[0m\u001b[35m  AI-driven policy enforcement. Real-time risk scoring.             \u2503\u001b[0m\r\n"]
[96.1, "o", "\u001b[1;35m  \u2503\u001b[0m\u001b[35m  Global federated trust \u2014 no single root of trust.               \u2503\u001b[0m\r\n"]
[96.3, "o", "\u001b[1;35m  \u2503\u001b[0m\u001b[35m  Certificate decisions in microseconds, not minutes.              \u2503\u001b[0m\r\n"]
[96.5, "o", "\u001b[1;35m  \u2503\u001b[0m\u001b[35m                                                                     \u2503\u001b[0m\r\n"]
[96.7, "o", "\u001b[1;35m  \u2503\u001b[0m\u001b[2m  Trust is earned continuously, not granted once.\u001b[0m\u001b[1;35m                    \u2503\u001b[0m\r\n"]
[96.9, "o", "\u001b[1;35m  \u2517\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u251b\u001b[0m\r\n"]
[99.9, "o", "\r\n"]
[100.2, "o", "\r\n"]
[100.5, "o", "\u001b[1;37m  \u250f\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2513\u001b[0m\r\n"]
[100.7, "o", "\u001b[1;37m  \u2503\u001b[0m\u001b[1;37m  2050: Quantum Native\u001b[0m\u001b[1;37m                                                \u2503\u001b[0m\r\n"]
[100.9, "o", "\u001b[1;37m  \u2503\u001b[0m\u001b[1;37m  \u2018Post-quantum\u2019 becomes just \u2018quantum.\u2019 The prefix is history.\u001b[0m\u001b[1;37m    \u2503\u001b[0m\r\n"]
[101.1, "o", "\u001b[1;37m  \u2503\u001b[0m\u001b[1;37m  Next-generation algorithms beyond ML-DSA and SLH-DSA.\u001b[0m\u001b[1;37m            \u2503\u001b[0m\r\n"]
[101.3, "o", "\u001b[1;37m  \u2503\u001b[0m\u001b[1;37m  PKI for interplanetary networks. Latency-tolerant trust.\u001b[0m\u001b[1;37m         \u2503\u001b[0m\r\n"]
[101.5, "o", "\u001b[1;37m  \u2503\u001b[0m\u001b[1;37m  Earth-to-Mars certificate chains. Light-speed is the bottleneck.\u001b[0m\u001b[1;37m \u2503\u001b[0m\r\n"]
[101.7, "o", "\u001b[1;37m  \u2503\u001b[0m\u001b[1;37m                                                                     \u2503\u001b[0m\r\n"]
[101.9, "o", "\u001b[1;37m  \u2503\u001b[0m\u001b[2m  We\u2019re not just securing the internet. We\u2019re securing the solar system.\u001b[0m\u001b[1;37m \u2503\u001b[0m\r\n"]
[102.1, "o", "\u001b[1;37m  \u2517\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u251b\u001b[0m\r\n"]
