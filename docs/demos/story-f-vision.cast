[97.1, "o", "\u001b[1;36m  \u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u001b[0m\r\n"]
[97.5, "o", "\r\n"]
[97.8, "o", "\u001b[1;37m                                       QuantumNexum\u001b[0m\r\n"]
[98.3, "o", "\u001b[2m                                Building for 2050. Shipping today.\u001b[0m\r\n"]
[99.1, "o", "\r\n"]
[99.4, "o", "\u001b[32m  \u2713 PKI-Client\u001b[0m\u001b[2m \u2014 19 commands. One binary. Post-quantum native.\u001b[0m\r\n"]
[99.9, "o", "\u001b[32m  \u2713 PKI-Signing-Service\u001b[0m\u001b[2m \u2014 multi-algorithm signing. Audit logging. API-first.\u001b[0m\r\n"]
[100.4, "o", "\u001b[32m  \u2713 PKI-CA-Engine\u001b[0m\u001b[2m \u2014 certificate authority as code. Declarative. Automated.\u001b[0m\r\n"]
[101.2, "o", "\r\n"]
