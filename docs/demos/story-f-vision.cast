[94.4, "o", "\u001b[32m  \u2713 PKI-Client\u001b[0m\u001b[2m \u2014 19 commands. One binary. Post-quantum native.\u001b[0m\r\n"]
[94.9, "o", "\u001b[32m  \u2713 PKI-Signing-Service\u001b[0m\u001b[2m \u2014 multi-algorithm signing. Audit logging. API-first.\u001b[0m\r\n"]
[95.4, "o", "\u001b[32m  \u2713 PKI-CA-Engine\u001b[0m\u001b[2m \u2014 certificate authority as code. Declarative. Automated.\u001b[0m\r\n"]
