[64.8, "o", "\r\n"]
[64.9, "o", "\r\n"]
[65.0, "o", "\r\n"]
[65.1, "o", "\u001b[1;36m  \u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501 The Road Ahead \u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u001b[0m\r\n"]
[65.5, "o", "\u001b[2m  The next quarter-century of cryptographic evolution.\u001b[0m\r\n"]
[67.5, "o", "\r\n"]
[67.8, "o", "\r\n"]
[68.1, "o", "\u001b[33m  \u250f\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2513\u001b[0m\r\n"]
[68.3, "o", "\u001b[33m  \u2503\u001b[0m\u001b[1;33m  2035: The Mandate\u001b[0m\u001b[33m                                                   \u2503\u001b[0m\r\n"]
[68.5, "o", "\u001b[33m  \u2503\u001b[0m\u001b[33m  NSA CNSA 2.0 deadline \u2014 all federal systems post-quantum.        \u2503\u001b[0m\r\n"]
[68.7, "o", "\u001b[33m  \u2503\u001b[0m\u001b[33m  Classical algorithms banned for new certificate issuance.         \u2503\u001b[0m\r\n"]
[68.9, "o", "\u001b[33m  \u2503\u001b[0m\u001b[33m  Every CA must support ML-DSA, ML-KEM, or SLH-DSA.                \u2503\u001b[0m\r\n"]
[69.1, "o", "\u001b[33m  \u2503\u001b[0m\u001b[33m                                                                     \u2503\u001b[0m\r\n"]
[69.3, "o", "\u001b[33m  \u2503\u001b[0m\u001b[2m  If you\u2019re not PQC by now, you\u2019re non-compliant.\u001b[0m\u001b[33m                    \u2503\u001b[0m\r\n"]
[69.5, "o", "\u001b[33m  \u2517\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u251b\u001b[0m\r\n"]
[72.5, "o", "\r\n"]
[72.8, "o", "\r\n"]
[73.1, "o", "\u001b[36m  \u250f\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2513\u001b[0m\r\n"]
[73.3, "o", "\u001b[36m  \u2503\u001b[0m\u001b[1;36m  2040: The Hybrid Sunset\u001b[0m\u001b[36m                                             \u2503\u001b[0m\r\n"]
[73.5, "o", "\u001b[36m  \u2503\u001b[0m\u001b[36m  Composite signatures deprecated \u2014 pure PQC only.                 \u2503\u001b[0m\r\n"]
[73.7, "o", "\u001b[36m  \u2503\u001b[0m\u001b[36m  Automated certificate lifecycle is the norm.                      \u2503\u001b[0m\r\n"]
[73.9, "o", "\u001b[36m  \u2503\u001b[0m\u001b[36m  Manual renewal is a compliance violation.                         \u2503\u001b[0m\r\n"]
[74.1, "o", "\u001b[36m  \u2503\u001b[0m\u001b[36m  Zero-touch issuance. Zero-touch revocation.                       \u2503\u001b[0m\r\n"]
[74.3, "o", "\u001b[36m  \u2503\u001b[0m\u001b[36m                                                                     \u2503\u001b[0m\r\n"]
[74.5, "o", "\u001b[36m  \u2503\u001b[0m\u001b[2m  The transition is over. Classical crypto is history.\u001b[0m\u001b[36m              \u2503\u001b[0m\r\n"]
[74.7, "o", "\u001b[36m  \u2517\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u251b\u001b[0m\r\n"]
[77.7, "o", "\r\n"]
[78.0, "o", "\r\n"]
[78.3, "o", "\u001b[1;35m  \u250f\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2513\u001b[0m\r\n"]
[78.5, "o", "\u001b[1;35m  \u2503\u001b[0m\u001b[1;35m  2045: Zero-Trust PKI\u001b[0m\u001b[1;35m                                                \u2503\u001b[0m\r\n"]
[78.7, "o", "\u001b[1;35m  \u2503\u001b[0m\u001b[35m  Hardware attestation + PQC replaces static certificates.         \u2503\u001b[0m\r\n"]
[78.9, "o", "\u001b[1;35m  \u2503\u001b[0m\u001b[35m  AI-driven policy enforcement. Real-time risk scoring.             \u2503\u001b[0m\r\n"]
[79.1, "o", "\u001b[1;35m  \u2503\u001b[0m\u001b[35m  Global federated trust \u2014 no single root of trust.               \u2503\u001b[0m\r\n"]
[79.3, "o", "\u001b[1;35m  \u2503\u001b[0m\u001b[35m  Certificate decisions in microseconds, not minutes.              \u2503\u001b[0m\r\n"]
[79.5, "o", "\u001b[1;35m  \u2503\u001b[0m\u001b[35m                                                                     \u2503\u001b[0m\r\n"]
[79.7, "o", "\u001b[1;35m  \u2503\u001b[0m\u001b[2m  Trust is earned continuously, not granted once.\u001b[0m\u001b[1;35m                    \u2503\u001b[0m\r\n"]
[79.9, "o", "\u001b[1;35m  \u2517\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u251b\u001b[0m\r\n"]
[82.9, "o", "\r\n"]
[83.2, "o", "\r\n"]
[83.5, "o", "\u001b[1;37m  \u250f\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2513\u001b[0m\r\n"]
[83.7, "o", "\u001b[1;37m  \u2503\u001b[0m\u001b[1;37m  2050: Quantum Native\u001b[0m\u001b[1;37m                                                \u2503\u001b[0m\r\n"]
[83.9, "o", "\u001b[1;37m  \u2503\u001b[0m\u001b[1;37m  \u2018Post-quantum\u2019 becomes just \u2018quantum.\u2019 The prefix is history.\u001b[0m\u001b[1;37m    \u2503\u001b[0m\r\n"]
[84.1, "o", "\u001b[1;37m  \u2503\u001b[0m\u001b[1;37m  Next-generation algorithms beyond ML-DSA and SLH-DSA.\u001b[0m\u001b[1;37m            \u2503\u001b[0m\r\n"]
[84.3, "o", "\u001b[1;37m  \u2503\u001b[0m\u001b[1;37m  PKI for interplanetary networks. Latency-tolerant trust.\u001b[0m\u001b[1;37m         \u2503\u001b[0m\r\n"]
[84.5, "o", "\u001b[1;37m  \u2503\u001b[0m\u001b[1;37m  Earth-to-Mars certificate chains. Light-speed is the bottleneck.\u001b[0m\u001b[1;37m \u2503\u001b[0m\r\n"]
[84.7, "o", "\u001b[1;37m  \u2503\u001b[0m\u001b[1;37m                                                                     \u2503\u001b[0m\r\n"]
[84.9, "o", "\u001b[1;37m  \u2503\u001b[0m\u001b[2m  We\u2019re not just securing the internet. We\u2019re securing the solar system.\u001b[0m\u001b[1;37m \u2503\u001b[0m\r\n"]
[85.1, "o", "\u001b[1;37m  \u2517\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u251b\u001b[0m\r\n"]
