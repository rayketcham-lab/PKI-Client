[16.0, "o", "\u001b[16;32H\u001b[0;36m\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u001b[0m\u001b[24;32H\u001b[0;36m\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u001b[0m"]
[18.3, "o", "\u001b[2J\u001b[1;1H"]
[18.8, "o", "\u001b[2J\u001b[1;1H"]
[19.3, "o", "\r\n"]
[19.4, "o", "\r\n"]
[19.5, "o", "\r\n"]
[19.6, "o", "\u001b[1;36m  \u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501 The Evolution of Trust \u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u001b[0m\r\n"]
[20.0, "o", "\u001b[2m  From broken hashes to quantum-safe signatures\u001b[0m\r\n"]
[22.0, "o", "\r\n"]
[22.2, "o", "\u001b[2m  Building the chain of trust, era by era...\u001b[0m\r\n"]
[22.6, "o", "\r\n"]
[23.0, "o", "\u001b[31m  \u2715 MD5 + RSA-1024\u001b[0m\u001b[2m  ............  ~2004\u001b[0m\r\n"]
[23.3, "o", "\u001b[2m    Collision attacks proved practical. The wake-up call.\u001b[0m\r\n"]
[24.7, "o", "\r\n"]
[25.1, "o", "\u001b[2m    \u2502\u001b[0m\r\n"]
[25.3, "o", "\u001b[33m  \u25b6 SHA-1 + RSA-2048\u001b[0m\u001b[2m  ..........  ~2011\u001b[0m\r\n"]
[25.6, "o", "\u001b[2m    Browsers deprecated SHA-1 by 2017. Too little, too late.\u001b[0m\r\n"]
[27.0, "o", "\r\n"]
[27.4, "o", "\u001b[2m    \u2502\u001b[0m\r\n"]
[27.6, "o", "\u001b[33m  \u25b6 SHA-256 + RSA-4096\u001b[0m\u001b[2m  .........  ~2017\u001b[0m\r\n"]
[27.9, "o", "\u001b[2m    CA/Browser Forum mandated SHA-256. The new baseline.\u001b[0m\r\n"]
[29.3, "o", "\r\n"]
[29.7, "o", "\u001b[2m    \u2502\u001b[0m\r\n"]
[29.9, "o", "\u001b[32m  \u25b6 SHA-384 + ECDSA-P384\u001b[0m\u001b[2m  .......  ~2020\u001b[0m\r\n"]
[30.2, "o", "\u001b[2m    Let\u2019s Encrypt and Cloudflare drove ECC adoption.\u001b[0m\r\n"]
[31.6, "o", "\r\n"]
[32.0, "o", "\u001b[2m    \u2502\u001b[0m\r\n"]
[32.2, "o", "\u001b[1;36m  \u25b6 ML-DSA-87\u001b[0m\u001b[2m  ...............  2024+\u001b[0m\r\n"]
[32.5, "o", "\u001b[2m    FIPS 204 published August 2024. The quantum era begins.\u001b[0m\r\n"]
[34.5, "o", "\r\n"]
[35.0, "o", "\u001b[2m  Timeline:\u001b[0m\r\n"]
[35.3, "o", "\u001b[31m  [2004]\u001b[0m\u001b[2m\u2500\u2500\u2500\u2500\u2500\u2500\u001b[0m\u001b[33m[2011]\u001b[0m\u001b[2m\u2500\u2500\u2500\u2500\u2500\u2500\u001b[0m\u001b[33m[2017]\u001b[0m\u001b[2m\u2500\u2500\u2500\u2500\u2500\u2500\u001b[0m\u001b[32m[2020]\u001b[0m\u001b[2m\u2500\u2500\u2500\u2500\u2500\u2500\u001b[0m\u001b[1;36m[2024+]\u001b[0m\r\n"]
[35.8, "o", "\u001b[31m  MD5/1024\u001b[0m\u001b[2m\u2500\u2500\u2500\u001b[0m\u001b[33m SHA1/2048\u001b[0m\u001b[2m\u2500\u2500\u001b[0m\u001b[33m SHA256/4096\u001b[0m\u001b[2m\u2500\u001b[0m\u001b[32m ECDSA-P384\u001b[0m\u001b[2m\u2500\u001b[0m\u001b[1;36m ML-DSA-87\u001b[0m\r\n"]
[37.3, "o", "\r\n"]
[37.8, "o", "\u001b[2m  Twenty years. Five generations. One direction: forward.\u001b[0m\r\n"]
[39.8, "o", "\r\n"]
[40.8, "o", "\r\n"]
[42.3, "o", "\u001b[2J\u001b[1;1H"]
[42.8, "o", "\r\n"]
