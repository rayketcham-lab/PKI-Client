[42.3, "o", "\u001b[33m  \u25b6 SHA-1 + RSA-2048\u001b[0m\u001b[2m  ..........  ~2011\u001b[0m\r\n"]
[42.6, "o", "\u001b[2m    Browsers deprecated SHA-1 by 2017. Too little, too late.\u001b[0m\r\n"]
[44.0, "o", "\r\n"]
[44.4, "o", "\u001b[2m    \u2502\u001b[0m\r\n"]
[44.6, "o", "\u001b[33m  \u25b6 SHA-256 + RSA-4096\u001b[0m\u001b[2m  .........  ~2017\u001b[0m\r\n"]
[44.9, "o", "\u001b[2m    CA/Browser Forum mandated SHA-256. The new baseline.\u001b[0m\r\n"]
[46.3, "o", "\r\n"]
[46.7, "o", "\u001b[2m    \u2502\u001b[0m\r\n"]
[46.9, "o", "\u001b[32m  \u25b6 SHA-384 + ECDSA-P384\u001b[0m\u001b[2m  .......  ~2020\u001b[0m\r\n"]
[47.2, "o", "\u001b[2m    Let\u2019s Encrypt and Cloudflare drove ECC adoption.\u001b[0m\r\n"]
[48.6, "o", "\r\n"]
[49.0, "o", "\u001b[2m    \u2502\u001b[0m\r\n"]
[49.2, "o", "\u001b[1;36m  \u25b6 ML-DSA-87\u001b[0m\u001b[2m  ...............  2024+\u001b[0m\r\n"]
[49.5, "o", "\u001b[2m    FIPS 204 published August 2024. The quantum era begins.\u001b[0m\r\n"]
[51.5, "o", "\r\n"]
[52.0, "o", "\u001b[2m  Timeline:\u001b[0m\r\n"]
[52.3, "o", "\u001b[31m  [2004]\u001b[0m\u001b[2m\u2500\u2500\u2500\u2500\u2500\u2500\u001b[0m\u001b[33m[2011]\u001b[0m\u001b[2m\u2500\u2500\u2500\u2500\u2500\u2500\u001b[0m\u001b[33m[2017]\u001b[0m\u001b[2m\u2500\u2500\u2500\u2500\u2500\u2500\u001b[0m\u001b[32m[2020]\u001b[0m\u001b[2m\u2500\u2500\u2500\u2500\u2500\u2500\u001b[0m\u001b[1;36m[2024+]\u001b[0m\r\n"]
[52.8, "o", "\u001b[31m  MD5/1024\u001b[0m\u001b[2m\u2500\u2500\u2500\u001b[0m\u001b[33m SHA1/2048\u001b[0m\u001b[2m\u2500\u2500\u001b[0m\u001b[33m SHA256/4096\u001b[0m\u001b[2m\u2500\u001b[0m\u001b[32m ECDSA-P384\u001b[0m\u001b[2m\u2500\u001b[0m\u001b[1;36m ML-DSA-87\u001b[0m\r\n"]
[54.3, "o", "\r\n"]
[54.8, "o", "\u001b[2m  Twenty years. Five generations. One direction: forward.\u001b[0m\r\n"]
[56.8, "o", "\r\n"]
[57.8, "o", "\r\n"]
