[14.5, "o", "\u001b[2J\u001b[1;1H\u001b[3;46H\u001b[1;37mThe clock is already ticking.\u001b[0m\u001b[4;39H\u001b[2mFederal PQC compliance deadlines \u2014 CNSA 2.0\u001b[0m\u001b[7;14H\u001b[0;90m\u2503\u001b[0m\u001b[7;18H\u001b[0;90m2017\u001b[0m\u001b[7;26H\u001b[0;90mSHA-1 distrusted\u001b[0m\u001b[8;14H\u001b[0;90m\u2503\u001b[0m\u001b[8;26H\u001b[2mBrowsers kill SHA-1. The last easy migration.\u001b[0m\u001b[9;14H\u001b[0;36m\u2503\u001b[0m\u001b[10;14H\u001b[0;36m\u2503\u001b[0m\u001b[10;18H\u001b[0;36m2024\u001b[0m\u001b[10;26H\u001b[0;36mFIPS 203 / 204 / 205\u001b[0m\u001b[11;14H\u001b[0;36m\u2503\u001b[0m\u001b[11;26H\u001b[2mNIST finalizes ML-KEM, ML-DSA, SLH-DSA.\u001b[0m\u001b[12;14H\u001b[1;36m\u2503\u001b[0m\u001b[13;14H\u001b[1;36m\u2503\u001b[0m\u001b[13;18H\u001b[1;36m2025\u001b[0m\u001b[13;26H\u001b[1;36mSoftware signing\u001b[0m\u001b[14;14H\u001b[1;36m\u2503\u001b[0m\u001b[14;26H\u001b[2mCNSA 2.0: firmware & software must use PQC.\u001b[0m\u001b[15;14H\u001b[1;33m\u2503\u001b[0m\u001b[16;14H\u001b[1;33m\u2503\u001b[0m\u001b[16;18H\u001b[1;33m2027\u001b[0m\u001b[16;26H\u001b[1;33mNew acquisitions\u001b[0m\u001b[17;14H\u001b[1;33m\u2503\u001b[0m\u001b[17;26H\u001b[2mAll new NSS procurements require PQC capability.\u001b[0m\u001b[18;14H\u001b[1;31m\u2503\u001b[0m\u001b[19;14H\u001b[1;31m\u2503\u001b[0m\u001b[19;18H\u001b[1;31m2030\u001b[0m\u001b[19;26H\u001b[1;31mWeb / network\u001b[0m\u001b[20;14H\u001b[1;31m\u2503\u001b[0m\u001b[20;26H\u001b[2mTLS, VPN, protocols must be PQC. No exceptions.\u001b[0m\u001b[21;14H\u001b[1;91m\u2503\u001b[0m\u001b[22;14H\u001b[1;91m\u2503\u001b[0m\u001b[22;18H\u001b[1;91m2035\u001b[0m\u001b[22;26H\u001b[1;91mFull migration\u001b[0m\u001b[23;14H\u001b[1;91m\u2503\u001b[0m\u001b[23;26H\u001b[2mAll national security systems: PQC or decommission.\u001b[0m\u001b[24;14H\u001b[1;35m\u2503\u001b[0m\u001b[25;14H\u001b[1;35m\u2503\u001b[0m\u001b[25;18H\u001b[1;35m2050\u001b[0m\u001b[25;26H\u001b[1;35m? ? ?\u001b[0m\u001b[26;