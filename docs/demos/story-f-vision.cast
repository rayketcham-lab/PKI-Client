[101.6, "o", "\u001b[1;36m  \u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u001b[0m\r\n"]
[102.0, "o", "\r\n"]
[102.3, "o", "\u001b[1;37m                                       QuantumNexum\u001b[0m\r\n"]
[102.8, "o", "\u001b[2m                                Building for 2050. Shipping today.\u001b[0m\r\n"]
[103.6, "o", "\r\n"]
[103.9, "o", "\u001b[32m  \u2713 PKI-Client\u001b[0m\u001b[2m \u2014 19 commands. One binary. Post-quantum native.\u001b[0m\r\n"]
[104.4, "o", "\u001b[32m  \u2713 PKI-Signing-Service\u001b[0m\u001b[2m \u2014 multi-algorithm signing. Audit logging. API-first.\u001b[0m\r\n"]
[104.9, "o", "\u001b[32m  \u2713 PKI-CA-Engine\u001b[0m\u001b[2m \u2014 certificate authority as code. Declarative. Automated.\u001b[0m\r\n"]
[105.7, "o", "\r\n"]
