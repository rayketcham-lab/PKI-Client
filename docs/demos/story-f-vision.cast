[60.2, "o", "\u001b[2m  Key:      \u001b[0m RSA 4096-bit \u2192 ML-DSA-87\u001b[31m  \u2717 DIFFERS\u001b[0m\r\n"]
[60.4, "o", "\u001b[2m  Signature:\u001b[0m sha256WithRSAEncryption \u2192 ML-DSA-87\u001b[31m  \u2717 DIFFERS\u001b[0m\r\n"]
[62.4, "o", "\r\n"]
