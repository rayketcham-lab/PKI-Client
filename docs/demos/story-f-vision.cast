[18.3, "o", "\u001b[14;31H\u001b[0;36m\u2554\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2557\u001b[0m\u001b[15;31H\u001b[0;36m\u2551                                                          \u2551\u001b[0m\u001b[16;31H\u001b[0;36m\u2551                                                          \u2551\u001b[0m\u001b[17;31H\u001b[0;36m\u2551                                                          \u2551\u001b[0m\u001b[18;31H\u001b[0;36m\u2551                                                          \u2551\u001b[0m\u001b[19;31H\u001b[0;36m\u2551                                                          \u2551\u001b[0m\u001b[20;31H\u001b[0;36m\u2551                                                          \u2551\u001b[0m\u001b[21;31H\u001b[0;36m\u2551                                                          \u2551\u001b[0m\u001b[22;31H\u001b[0;36m\u2551                                                          \u2551\u001b[0m\u001b[23;31H\u001b[0;36m\u2551                                                          \u2551\u001b[0m\u001b[24;31H\u001b[0;36m\u2551                                                          \u2551\u001b[0m\u001b[25;31H\u001b[0;36m\u255a\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u255d\u001b[0m"]
[18.8, "o", "\u001b[18;48H\u001b[1;37mQ U A N T U M   N E X U M\u001b[0m"]
[19.3, "o", "\u001b[20;53H\u001b[2mp r e s e n t s\u001b[0m"]
[20.0, "o", "\u001b[16;32H\u001b[0;36m\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u001b[0m\u001b[24;32H\u001b[0;36m\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u001b[0m"]
[22.3, "o", "\u001b[2J\u001b[1;1H"]
[22.8, "o", "\u001b[2J\u001b[1;1H"]
[23.3, "o", "\r\n"]
[23.4, "o", "\r\n"]
[23.5, "o", "\r\n"]
[23.6, "o", "\u001b[1;36m  \u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501 The Evolution of Trust \u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u001b[0m\r\n"]
[24.0, "o", "\u001b[2m  From broken hashes to quantum-safe signatures\u001b[0m\r\n"]
[26.0, "o", "\r\n"]
[26.2, "o", "\u001b[2m  Building the chain of trust, era by era...\u001b[0m\r\n"]
[26.6, "o", "\r\n"]
[27.0, "o", "\u001b[31m  \u2715 MD5 + RSA-1024\u001b[0m\u001b[2m  ............  ~2004\u001b[0m\r\n"]
[27.3, "o", "\u001b[2m    Collision attacks proved practical. The wake-up call.\u001b[0m\r\n"]
[28.7, "o", "\r\n"]
[29.1, "o", "\u001b[2m    \u2502\u001b[0m\r\n"]
[29.3, "o", "\u001b[33m  \u25b6 SHA-1 + RSA-2048\u001b[0m\u001b[2m  ..........  ~2011\u001b[0m\r\n"]
[29.6, "o", "\u001b[2m    Browsers deprecated SHA-1 by 2017. Too little, too late.\u001b[0m\r\n"]
[31.0, "o", "\r\n"]
[31.4, "o", "\u001b[2m    \u2502\u001b[0m\r\n"]
[31.6, "o", "\u001b[33m  \u25b6 SHA-256 + RSA-4096\u001b[0m\u001b[2m  .........  ~2017\u001b[0m\r\n"]
[31.9, "o", "\u001b[2m    CA/Browser Forum mandated SHA-256. The new baseline.\u001b[0m\r\n"]
[33.3, "o", "\r\n"]
[33.7, "o", "\u001b[2m    \u2502\u001b[0m\r\n"]
[33.9, "o", "\u001b[32m  \u25b6 SHA-384 + ECDSA-P384\u001b[0m\u001b[2m  .......  ~2020\u001b[0m\r\n"]
[34.2, "o", "\u001b[2m    Let\u2019s Encrypt and Cloudflare drove ECC adoption.\u001b[0m\r\n"]
[35.6, "o", "\r\n"]
[36.0, "o", "\u001b[2m    \u2502\u001b[0m\r\n"]
[36.2, "o", "\u001b[1;36m  \u25b6 ML-DSA-87\u001b[0m\u001b[2m  ...............  2024+\u001b[0m\r\n"]
[36.5, "o", "\u001b[2m    FIPS 204 published August 2024. The quantum era begins.\u001b[0m\r\n"]
[38.5, "o", "\r\n"]
[39.0, "o", "\u001b[2m  Timeline:\u001b[0m\r\n"]
[39.3, "o", "\u001b[31m  [2004]\u001b[0m\u001b[2m\u2500\u2500\u2500\u2500\u2500\u2500\u001b[0m\u001b[33m[2011]\u001b[0m\u001b[2m\u2500\u2500\u2500\u2500\u2500\u2500\u001b[0m\u001b[33m[2017]\u001b[0m\u001b[2m\u2500\u2500\u2500\u2500\u2500\u2500\u001b[0m\u001b[32m[2020]\u001b[0m\u001b[2m\u2500\u2500\u2500\u2500\u2500\u2500\u001b[0m\u001b[1;36m[2024+]\u001b[0m\r\n"]
[39.8, "o", "\u001b[31m  MD5/1024\u001b[0m\u001b[2m\u2500\u2500\u2500\u001b[0m\u001b[33m SHA1/2048\u001b[0m\u001b[2m\u2500\u2500\u001b[0m\u001b[33m SHA256/4096\u001b[0m\u001b[2m\u2500\u001b[0m\u001b[32m ECDSA-P384\u001b[0m\u001b[2m\u2500\u001b[0m\u001b[1;36m ML-DSA-87\u001b[0m\r\n"]
[41.3, "o", "\r\n"]
[41.8, "o", "\u001b[2m  Twenty years. Five generations. One direction: forward.\u001b[0m\r\n"]
[43.8, "o", "\r\n"]
[44.8, "o", "\r\n"]
