[4.71, "o", "\r\n"]
[5.01, "o", "pki 0.7.0\r\n"]
[5.712, "o", "\u001b[1;32mpki>\u001b[0m "]
[6.012, "o", "h"]
[6.042, "o", "e"]
[6.072, "o", "l"]
[6.102, "o", "p"]
[6.132, "o", "\r\n"]
[6.432, "o", "PKI Interactive Shell - PKI operations made human\r\n"]
[6.434, "o", "\r\n"]
[6.436, "o", "Commands:\r\n"]
[6.438, "o", "  show <file>                   Show certificate details (shortcut)\r\n"]
[6.44, "o", "  show <file> --lint            Run security lint checks\r\n"]
[6.442, "o", "  show <file> --check           Check revocation status (OCSP/CRL)\r\n"]
[6.444, "o", "  show <file> --all             Full analysis (details + lint + revocation)\r\n"]
[6.446, "o", "  show <file> --interactive     Interactive menu mode\r\n"]
[6.448, "o", "\r\n"]
[6.45, "o", "  cert show <file>              Show certificate details\r\n"]
[6.452, "o", "  cert expires <file>           Check certificate expiration\r\n"]
[6.454, "o", "  cert fingerprint <file>       Show certificate fingerprint\r\n"]
[6.456, "o", "\r\n"]
[6.458, "o", "  csr create --key <file> --cn <name>   Create a CSR\r\n"]
[6.46, "o", "  csr show <file>               Show CSR details\r\n"]
[6.462, "o", "\r\n"]
[6.464, "o", "  key gen ec|rsa|ed25519        Generate private key\r\n"]
[6.466, "o", "  key show <file>               Show key information\r\n"]
[6.468, "o", "  key match <key> <cert>        Check if key matches certificate\r\n"]
[6.47, "o", "\r\n"]
[6.472, "o", "  chain build <file>            Build certificate chain\r\n"]
[6.474, "o", "  chain show <file>             Display chain as tree\r\n"]
[6.476, "o", "  chain verify <file>           Verify chain integrity\r\n"]
[6.478, "o", "\r\n"]
[6.48, "o", "  convert <file> --to pem|der   Convert certificate format\r\n"]
[6.482, "o", "  diff <file1> <file2>          Compare two certs or CSRs\r\n"]
[6.484, "o", "  probe server <host:port>      Probe TLS server\r\n"]
[6.486, "o", "  probe check <host:port>       Quick TLS connectivity check\r\n"]
[6.488, "o", "\r\n"]
[6.49, "o", "  scep cacaps <url>             SCEP: CA capabilities\r\n"]
[6.492, "o", "  scep enroll <url> -s <cn>     SCEP: automated enrollment\r\n"]
[6.494, "o", "  acme certonly <domain>        ACME: get certificate\r\n"]
[6.496, "o", "  est enroll <url>              EST: simple enrollment\r\n"]
[6.498, "o", "\r\n"]
[6.5, "o", "Shell commands:\r\n"]
[6.502, "o", "  help, ?                       Show this help\r\n"]
[6.504, "o", "  version                       Show version\r\n"]
[6.506, "o", "  history                       Show command history\r\n"]
[6.508, "o", "  clear                         Clear screen\r\n"]
[6.51, "o", "  exit, quit, q                 Exit shell\r\n"]
[6.512, "o", "\r\n"]
[6.514, "o", "Tips:\r\n"]
[6.516, "o", "  - Use Tab for file path completion\r\n"]
[6.518, "o", "  - Use Up/Down arrows for history\r\n"]
[6.52, "o", "  - The \"pki\" prefix is optional (e.g., \"key gen ec\" works)\r\n"]
[6.522, "o", "  - Paste PEM certificates directly to view them\r\n"]
[8.224, "o", "\r\n\u001b[1;33m\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u001b[0m\r\n"]
