[3.632, "o", "  \u001b[1;36m\u2588\u2588\u2551     \u2588\u2588\u2551  \u2588\u2588\u2557\u2588\u2588\u2551\u001b[0m\r\n"]
[3.635, "o", "  \u001b[1;36m\u255a\u2550\u255d     \u255a\u2550\u255d  \u255a\u2550\u255d\u255a\u2550\u255d\u001b[0m\r\n"]
[3.638, "o", "\r\n"]
[3.641, "o", "  \u001b[1;37mPKI\u001b[0m - \u001b[2mModern PKI Operations Tool\u001b[0m\r\n"]
[3.644, "o", "\r\n"]
[3.647, "o", "  \u001b[2mType help for commands, exit to quit\u001b[0m\r\n"]
