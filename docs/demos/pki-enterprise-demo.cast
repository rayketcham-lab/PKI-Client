[3.485, "o", "  \u001b[1;36m\u255a\u2550\u255d     \u255a\u2550\u255d  \u255a\u2550\u255d\u255a\u2550\u255d\u001b[0m\r\n"]
[3.488, "o", "\r\n"]
[3.491, "o", "  \u001b[1;37mPKI\u001b[0m - \u001b[2mModern PKI Operations Tool\u001b[0m\r\n"]
[3.494, "o", "\r\n"]
[3.497, "o", "  \u001b[2mType help for commands, exit to quit\u001b[0m\r\n"]
[4.2, "o", "\u001b[1;32mpki>\u001b[0m "]
[4.5, "o", "v"]
[4.53, "o", "e"]
