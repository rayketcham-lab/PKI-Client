[4.86, "o", "\r\n"]
[5.16, "o", "pki 0.7.0\r\n"]
[5.862, "o", "\u001b[1;32mpki>\u001b[0m "]
[6.162, "o", "h"]
[6.192, "o", "e"]
[6.222, "o", "l"]
[6.252, "o", "p"]
[6.282, "o", "\r\n"]
[6.582, "o", "PKI Interactive Shell - PKI operations made human\r\n"]
[6.584, "o", "\r\n"]
[6.586, "o", "Commands:\r\n"]
[6.588, "o", "  show <file>                   Show certificate details (shortcut)\r\n"]
[6.59, "o", "  show <file> --lint            Run security lint checks\r\n"]
[6.592, "o", "  show <file> --check           Check revocation status (OCSP/CRL)\r\n"]
[6.594, "o", "  show <file> --all             Full analysis (details + lint + revocation)\r\n"]
[6.596, "o", "  show <file> --interactive     Interactive menu mode\r\n"]
[6.598, "o", "\r\n"]
[6.6, "o", "  cert show <file>              Show certificate details\r\n"]
[6.602, "o", "  cert expires <file>           Check certificate expiration\r\n"]
[6.604, "o", "  cert fingerprint <file>       Show certificate fingerprint\r\n"]
[6.606, "o", "\r\n"]
[6.608, "o", "  csr create --key <file> --cn <name>   Create a CSR\r\n"]
[6.61, "o", "  csr show <file>               Show CSR details\r\n"]
[6.612, "o", "\r\n"]
[6.614, "o", "  key gen ec|rsa|ed25519        Generate private key\r\n"]
[6.616, "o", "  key show <file>               Show key information\r\n"]
[6.618, "o", "  key match <key> <cert>        Check if key matches certificate\r\n"]
[6.62, "o", "\r\n"]
[6.622, "o", "  chain build <file>            Build certificate chain\r\n"]
[6.624, "o", "  chain show <file>             Display chain as tree\r\n"]
[6.626, "o", "  chain verify <file>           Verify chain integrity\r\n"]
[6.628, "o", "\r\n"]
[6.63, "o", "  convert <file> --to pem|der   Convert certificate format\r\n"]
[6.632, "o", "  diff <file1> <file2>          Compare two certs or CSRs\r\n"]
[6.634, "o", "  probe server <host:port>      Probe TLS server\r\n"]
[6.636, "o", "  probe check <host:port>       Quick TLS connectivity check\r\n"]
[6.638, "o", "\r\n"]
[6.64, "o", "  scep cacaps <url>             SCEP: CA capabilities\r\n"]
[6.642, "o", "  scep enroll <url> -s <cn>     SCEP: automated enrollment\r\n"]
[6.644, "o", "  acme certonly <domain>        ACME: get certificate\r\n"]
[6.646, "o", "  est enroll <url>              EST: simple enrollment\r\n"]
[6.648, "o", "\r\n"]
[6.65, "o", "Shell commands:\r\n"]
[6.652, "o", "  help, ?                       Show this help\r\n"]
[6.654, "o", "  version                       Show version\r\n"]
[6.656, "o", "  history                       Show command history\r\n"]
[6.658, "o", "  clear                         Clear screen\r\n"]
[6.66, "o", "  exit, quit, q                 Exit shell\r\n"]
[6.662, "o", "\r\n"]
[6.664, "o", "Tips:\r\n"]
[6.666, "o", "  - Use Tab for file path completion\r\n"]
[6.668, "o", "  - Use Up/Down arrows for history\r\n"]
[6.67, "o", "  - The \"pki\" prefix is optional (e.g., \"key gen ec\" works)\r\n"]
[6.672, "o", "  - Paste PEM certificates directly to view them\r\n"]
[8.374, "o", "\r\n\u001b[1;33m\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u001b[0m\r\n"]
