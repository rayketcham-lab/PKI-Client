[11.9, "o", "  \u001b[1;32m\u2713\u001b[0m No signtool.exe    \u001b[1;32m\u2713\u001b[0m No OpenSSL    \u001b[1;32m\u2713\u001b[0m Pure Rust\r\n"]
[11.9, "o", "  \u001b[1;32m\u2713\u001b[0m Post-quantum ready \u001b[1;32m\u2713\u001b[0m Audit trails  \u001b[1;32m\u2713\u001b[0m Static binary\r\n"]
