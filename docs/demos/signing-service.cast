[62.11, "o", "\u001b[11;12H\u001b[0;37mProduction signing requires 2-person approval.\u001b[0m"]
[62.51, "o", "\u001b[12;12H\u001b[2;37mNo single engineer can sign + deploy.\u001b[0m"]
[63.51, "o", "\u001b[14;8H\u001b[1;36m▸ \u001b[0m\u001b[1;37mAudit Trail\u001b[0m"]
[64.01, "o", "\u001b[15;12H\u001b[0;37mEvery operation → immutable, queryable log.\u001b[0m"]
[64.41, "o", "\u001b[16;12H\u001b[2;37mWho signed what, when, which key, which hash.\u001b[0m"]
[65.41, "o", "\u001b[18;8H\u001b[1;36m▸ \u001b[0m\u001b[1;37mCertificate Lifecycle\u001b[0m"]
[65.91, "o", "\u001b[19;12H\u001b[0;37mSigning certs rotate annually. Revocation tested.\u001b[0m"]
[66.31, "o", "\u001b[20;12H\u001b[2;37mOld certs on CRL within 24h of rotation.\u001b[0m"]
[67.31, "o", "\u001b[22;8H\u001b[1;36m▸ \u001b[0m\u001b[1;37mScope Isolation\u001b[0m"]
[67.81, "o", "\u001b[23;12H\u001b[0;37mEach team gets its own signing cert + policy.\u001b[0m"]
[68.21, "o", "\u001b[24;12H\u001b[2;37mPlatform team can't sign mobile binaries.\u001b[0m"]
[72.21, "o", "\u001b[2J\u001b[H"]
[72.51, "o", "\u001b[2;4H\u001b[1;36m╔══════════════════════════════════════════════════════════════════════════════════════════════════════════════╗\u001b[0m\u001b[3;4H\u001b[1;36m║                                        4  BEFORE YOU SHIP — CHECKLIST                                        ║\u001b[0m\u001b[4;4H\u001b[1;36m╚══════════════════════════════════════════════════════════════════════════════════════════════════════════════╝\u001b[0m"]
[73.11, "o", "\u001b[6;8H\u001b[1;32m☑\u001b[0m  Signing key is HSM-backed, not a file on disk"]
[73.91, "o", "\u001b[8;8H\u001b[1;32m☑\u001b[0m  Batch limit enforced at API level (max 10)"]
[74.71, "o", "\u001b[10;8H\u001b[1;32m☑\u001b[0m  PE binaries dual-signed SHA-256 + SHA-384"]
[75.51, "o", "\u001b[12;8H\u001b[1;32m☑\u001b[0m  RFC 3161 timestamp authority configured"]
[76.31, "o", "\u001b[14;8H\u001b[1;32m☑\u001b[0m  Audit log captures: who, what, when, hash"]
[77.11, "o", "\u001b[16;8H\u001b[1;32m☑\u001b[0m  Signing cert scoped to team + environment"]
[77.91, "o", "\u001b[18;8H\u001b[1;32m☑\u001b[0m  Revocation plan documented and tested"]
[78.71, "o", "\u001b[20;8H\u001b[1;32m☑\u001b[0m  Post-quantum migration path identified"]
[80.51, "o", "\u001b[24;8H\u001b[1;37mAll green?  \u001b[0m\u001b[1;32mShip it.\u001b[0m"]
[84.01, "o", "\u001b[2J\u001b[H"]
[84.51, "o", "\u001b[18;1H                                                \u001b[2;37mBuilt for exactly this.\u001b[0m"]
[87.51, "o", "\u001b[2J\u001b[H"]
[87.81, "o", "\u001b[4;1H                                           \u001b[1;36mPKI-Signing-Service\u001b[0m\u001b[1;37m  +  \u001b[0m\u001b[1;36mPKI-Client\u001b[0m"]
[88.21, "o", "\u001b[6;1H                              \u001b[2;37mEnterprise code signing that enforces every practice above.\u001b[0m"]
[89.21, "o", "\u001b[9;8H\u001b[1;32m$ \u001b[0m\u001b[1;36mpki sign\u001b[0m app.exe --policy production"]
[89.71, "o", "\u001b[10;10H\u001b[2;37mSign PE binary with team-scoped production policy\u001b[0m"]
[90.71, "o", "\u001b[12;8H\u001b[1;32m$ \u001b[0m\u001b[1;36mpki sign\u001b[0m --batch manifest.txt --limit 10"]
[91.21, "o", "\u001b[13;10H\u001b[2;37mBatch sign up to 10 files from a manifest\u001b[0m"]
[92.21, "o", "\u001b[15;8H\u001b[1;32m$ \u001b[0m\u001b[1;36mpki verify\u001b[0m app.exe --authenticode --timestamp"]
[92.71, "o", "\u001b[16;10H\u001b[2;37mVerify Authenticode signature + timestamp offline\u001b[0m"]
[93.71, "o", "\u001b[18;8H\u001b[1;32m$ \u001b[0m\u001b[1;36mpki audit\u001b[0m --signer team-platform-01 --last 7d"]
[94.21, "o", "\u001b[19;10H\u001b[2;37mQuery audit trail — who signed what this week\u001b[0m"]
[95.21, "o", "\u001b[21;8H\u001b[1;32m$ \u001b[0m\u001b[1;36mpki hierarchy build\u001b[0m signing-ca.toml"]
[95.71, "o", "\u001b[22;10H\u001b[2;37mStand up your signing CA hierarchy from TOML\u001b[0m"]
