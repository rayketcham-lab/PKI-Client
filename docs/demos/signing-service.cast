[18.4, "o", "\u001b[2J\u001b[H"]
[18.7, "o", "\u001b[2;4H\u001b[1;36m\u2554\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2557\u001b[0m\u001b[3;4H\u001b[1;36m\u2551                                           1  BATCH SIGNING LIMITS                                            \u2551\u001b[0m\u001b[4;4H\u001b[1;36m\u255a\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u255d\u001b[0m"]
[19.3, "o", "\u001b[6;8H\u001b[1;32m\u2713\u001b[0m  Maximum \u001b[1;37m10 files\u001b[0m per signing request"]
[20.5, "o", "\u001b[8;8H\u001b[1;32m\u2713\u001b[0m  Prevents runaway automation from mass-signing"]
[21.7, "o", "\u001b[10;8H\u001b[1;32m\u2713\u001b[0m  Each batch gets a unique \u001b[1;36mtransaction ID\u001b[0m"]
[22.9, "o", "\u001b[12;8H\u001b[1;32m\u2713\u001b[0m  Partial success OK \u2014 failed files don't block the batch"]
[24.1, "o", "\u001b[14;8H\u001b[1;31m\u2717\u001b[0m  \u001b[1;31mNever\u001b[0m sign unbounded queues \u2014 enforce at the API"]
[25.8, "o", "\u001b[17;8H\u001b[2;37mExample request:\u001b[0m"]
[26.1, "o", "\u001b[18;10H\u001b[1;36mPOST\u001b[0m /api/v1/sign/batch"]
[26.35, "o", "\u001b[19;10H  {"]
[26.6, "o", "\u001b[20;10H    \"files\":     \u001b[1;32m[\"app.exe\", \"lib.dll\", \"drv.sys\"]\u001b[0m,"]
[26.85, "o", "\u001b[21;10H    \"policy\":    \u001b[1;32m\"production\"\u001b[0m,"]
[27.1, "o", "\u001b[22;10H    \"signer_id\": \u001b[1;32m\"team-platform-01\"\u001b[0m,"]
[27.35, "o", "\u001b[23;10H    \"timestamp\": \u001b[1;33mtrue\u001b[0m"]
[27.6, "o", "\u001b[24;10H  }"]
[28.15, "o", "\u001b[26;8H\u001b[1;33m\u26a0\u001b[0m\u001b[2;37m  Server rejects if files.len() > 10\u001b[0m"]
[31.15, "o", "\u001b[2J\u001b[H"]
[31.45, "o", "\u001b[2;4H\u001b[1;36m\u2554\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2557\u001b[0m\u001b[3;4H\u001b[1;36m\u2551                                               2  SIGNING TYPES                                               \u2551\u001b[0m\u001b[4;4H\u001b[1;36m\u255a\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u255d\u001b[0m"]
[32.05, "o", "\u001b[6;8H\u001b[1;37mArbitrary File Signing\u001b[0m\u001b[2;37m  (hash-based, any file)\u001b[0m"]
[32.55, "o", "\u001b[8;10H\u001b[1;32m\u2713\u001b[0m  Configs, firmware, containers, scripts, images"]
[33.55, "o", "\u001b[10;10H\u001b[1;32m\u2713\u001b[0m  \u001b[1;36mSHA-384\u001b[0m digest \u2192 sign the hash, not the file"]
[34.55, "o", "\u001b[12;10H\u001b[1;32m\u2713\u001b[0m  Detached signature: \u001b[2;37mfile.bin\u001b[0m + \u001b[1;36mfile.bin.sig\u001b[0m"]
[36.75, "o", "\u001b[15;8H\u001b[1;37mPE / Authenticode\u001b[0m\u001b[2;37m  (Windows executables)\u001b[0m"]
[37.25, "o", "\u001b[17;10H\u001b[1;32m\u2713\u001b[0m  .exe  .dll  .sys  .msi  .cab  .appx  .ps1"]
[38.25, "o", "\u001b[19;10H\u001b[1;32m\u2713\u001b[0m  Signature embeds \u001b[1;36minside the PE header\u001b[0m"]
[39.25, "o", "\u001b[21;10H\u001b[1;32m\u2713\u001b[0m  Dual-sign: SHA-256 + SHA-384 for backward compat"]
[40.25, "o", "\u001b[23;10H\u001b[1;33m\u26a0\u001b[0m  \u001b[1;37mTimestamping required\u001b[0m \u2014 certs expire, timestamps don't"]
[42.05, "o", "\u001b[26;8H\u001b[2;37mVerify offline:  \u001b[0m\u001b[1;32m$ \u001b[0m\u001b[1;36mpki verify\u001b[0m app.exe --authenticode"]
[45.05, "o", "\u001b[2J\u001b[H"]
[45.35, "o", "\u001b[2;4H\u001b[1;36m\u2554\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2557\u001b[0m\u001b[3;4H\u001b[1;36m\u2551                                          3  SERVICE RESPONSIBILITY                                           \u2551\u001b[0m\u001b[4;4H\u001b[1;36m\u255a\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u255d\u001b[0m"]
[45.95, "o", "\u001b[6;8H\u001b[1;36m\u25b8 \u001b[0m\u001b[1;37mKey Protection\u001b[0m"]
[46.45, "o", "\u001b[7;12H\u001b[0;37msoftware-protected (FIPS 140-3 Level 3). Never exportable.\u001b[0m"]
[46.85, "o", "\u001b[8;12H\u001b[2;37mKeys never leave hardware. Period.\u001b[0m"]
[47.85, "o", "\u001b[10;8H\u001b[1;36m\u25b8 \u001b[0m\u001b[1;37mApproval Workflow\u001b[0m"]
[48.35, "o", "\u001b[11;12H\u001b[0;37mProduction signing requires 2-person approval.\u001b[0m"]
[48.75, "o", "\u001b[12;12H\u001b[2;37mNo single engineer can sign + deploy.\u001b[0m"]
[49.75, "o", "\u001b[14;8H\u001b[1;36m\u25b8 \u001b[0m\u001b[1;37mAudit Trail\u001b[0m"]
[50.25, "o", "\u001b[15;12H\u001b[0;37mEvery operation \u2192 immutable, queryable log.\u001b[0m"]
[50.65, "o", "\u001b[16;12H\u001b[2;37mWho signed what, when, which key, which hash.\u001b[0m"]
[51.65, "o", "\u001b[18;8H\u001b[1;36m\u25b8 \u001b[0m\u001b[1;37mCertificate Lifecycle\u001b[0m"]
[52.15, "o", "\u001b[19;12H\u001b[0;37mSigning certs rotate annually. Revocation tested.\u001b[0m"]
[52.55, "o", "\u001b[20;12H\u001b[2;37mOld certs on CRL within 24h of rotation.\u001b[0m"]
[53.55, "o", "\u001b[22;8H\u001b[1;36m\u25b8 \u001b[0m\u001b[1;37mScope Isolation\u001b[0m"]
[54.05, "o", "\u001b[23;12H\u001b[0;37mEach team gets its own signing cert + policy.\u001b[0m"]
[54.45, "o", "\u001b[24;12H\u001b[2;37mPlatform team can't sign mobile binaries.\u001b[0m"]
[58.45, "o", "\u001b[2J\u001b[H"]
[58.75, "o", "\u001b[2;4H\u001b[1;36m\u2554\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2557\u001b[0m\u001b[3;4H\u001b[1;36m\u2551                                        4  BEFORE YOU SHIP \u2014 CHECKLIST                                        \u2551\u001b[0m\u001b[4;4H\u001b[1;36m\u255a\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u255d\u001b[0m"]
[59.35, "o", "\u001b[6;8H\u001b[1;32m\u2611\u001b[0m  Signing key is software-protected, not a file on disk"]
[60.15, "o", "\u001b[8;8H\u001b[1;32m\u2611\u001b[0m  Batch limit enforced at API level (max 10)"]
[60.95, "o", "\u001b[10;8H\u001b[1;32m\u2611\u001b[0m  PE binaries dual-signed SHA-256 + SHA-384"]
[61.75, "o", "\u001b[12;8H\u001b[1;32m\u2611\u001b[0m  RFC 3161 timestamp authority configured"]
[62.55, "o", "\u001b[14;8H\u001b[1;32m\u2611\u001b[0m  Audit log captures: who, what, when, hash"]
[63.35, "o", "\u001b[16;8H\u001b[1;32m\u2611\u001b[0m  Signing cert scoped to team + environment"]
[64.15, "o", "\u001b[18;8H\u001b[1;32m\u2611\u001b[0m  Revocation plan documented and tested"]
[64.95, "o", "\u001b[20;8H\u001b[1;32m\u2611\u001b[0m  Post-quantum migration path identified"]
[66.75, "o", "\u001b[24;8H\u001b[1;37mAll green?  \u001b[0m\u001b[1;32mShip it.\u001b[0m"]
[70.25, "o", "\u001b[2J\u001b[H"]
[70.75, "o", "\u001b[18;1H                                                \u001b[2;37mBuilt for exactly this.\u001b[0m"]
[73.75, "o", "\u001b[2J\u001b[H"]
[74.05, "o", "\u001b[4;1H                                           \u001b[1;36mPKI-Signing-Service\u001b[0m\u001b[1;37m  +  \u001b[0m\u001b[1;36mPKI-Client\u001b[0m"]
[74.45, "o", "\u001b[6;1H                              \u001b[2;37mEnterprise code signing that enforces every practice above.\u001b[0m"]
[75.45, "o", "\u001b[9;8H\u001b[1;32m$ \u001b[0m\u001b[1;36mpki sign\u001b[0m app.exe --policy production"]
[75.95, "o", "\u001b[10;10H\u001b[2;37mSign PE binary with team-scoped production policy\u001b[0m"]
[76.95, "o", "\u001b[12;8H\u001b[1;32m$ \u001b[0m\u001b[1;36mpki sign\u001b[0m --batch manifest.txt --limit 10"]
[77.45, "o", "\u001b[13;10H\u001b[2;37mBatch sign up to 10 files from a manifest\u001b[0m"]
[78.45, "o", "\u001b[15;8H\u001b[1;32m$ \u001b[0m\u001b[1;36mpki verify\u001b[0m app.exe --authenticode --timestamp"]
[78.95, "o", "\u001b[16;10H\u001b[2;37mVerify Authenticode signature + timestamp offline\u001b[0m"]
[79.95, "o", "\u001b[18;8H\u001b[1;32m$ \u001b[0m\u001b[1;36mpki audit\u001b[0m --signer team-platform-01 --last 7d"]
[80.45, "o", "\u001b[19;10H\u001b[2;37mQuery audit trail \u2014 who signed what this week\u001b[0m"]
[81.45, "o", "\u001b[21;8H\u001b[1;32m$ \u001b[0m\u001b[1;36mpki hierarchy build\u001b[0m signing-ca.toml"]
[81.95, "o", "\u001b[22;10H\u001b[2;37mStand up your signing CA hierarchy from TOML\u001b[0m"]
[85.95, "o", "\u001b[2J\u001b[H"]
[86.25, "o", "\u001b[12;1H                                               \u001b[1;37mThe QuantumNexum PKI Suite\u001b[0m"]
[86.75, "o", "\u001b[14;1H                                \u001b[2;37mThree tools.  One mission.  Quantum-safe infrastructure.\u001b[0m"]
[87.75, "o", "\u001b[17;10H\u001b[1;36mPKI-Client              \u001b[0m\u001b[2;37mCertificate lifecycle CLI \u2014 inspect, lint, diff, probe, enroll\u001b[0m"]
[88.35, "o", "\u001b[19;10H\u001b[1;36mPKI-Signing-Service     \u001b[0m\u001b[2;37mEnterprise code signing \u2014 batch limits, audit logging, Authenticode\u001b[0m"]
