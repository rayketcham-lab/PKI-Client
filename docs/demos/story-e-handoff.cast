[78.6, "o", "\r\n"]
[78.8, "o", "\r\n"]
[79.0, "o", "  \u001b[1;37mTLS Probe: quantumnexum.com:443\u001b[0m\r\n"]
[79.2, "o", "\r\n"]
[79.4, "o", "  Protocol       : \u001b[1;32mTLS 1.3\u001b[0m\r\n"]
[79.6, "o", "  Cipher Suite   : \u001b[1;32mTLS_AES_256_GCM_SHA384\u001b[0m\r\n"]
[79.8, "o", "  Key Exchange   : \u001b[1;36mML-KEM-768 + X25519 (hybrid)\u001b[0m\r\n"]
[80.0, "o", "  Server Cert    : \u001b[1;37mCN=quantumnexum.com\u001b[0m\r\n"]
[80.2, "o", "  Signature Algo : \u001b[1;36mML-DSA-87\u001b[0m\r\n"]
[80.4, "o", "  Cert Valid     : \u001b[32mYes\u001b[0m  (not before: 2026-03-01, not after: 2027-03-01)\r\n"]
[80.6, "o", "  OCSP Stapling  : \u001b[32mPresent\u001b[0m\r\n"]
[80.8, "o", "  CT Logs        : \u001b[32m2 SCTs embedded\u001b[0m\r\n"]
[81.0, "o", "\r\n"]
[81.3, "o", "  \u001b[1;37mCertificate Chain (3 certs)\u001b[0m\r\n"]
[81.5, "o", "    [0] CN=quantumnexum.com             \u001b[32mVALID\u001b[0m  ML-DSA-87  expires 2027-03-01\r\n"]
[81.7, "o", "    [1] CN=QuantumNexum Issuing CA      \u001b[32mVALID\u001b[0m  ML-DSA-87  expires 2031-03-01\r\n"]
[81.9, "o", "    [2] CN=QuantumNexum PQC Root CA     \u001b[32mVALID\u001b[0m  ML-DSA-87  expires 2036-03-01\r\n"]
[82.1, "o", "\r\n"]
[82.4, "o", "  \u001b[0;90mTLS version, cipher, key exchange, cert chain \u2014 all in one command.\u001b[0m\r\n"]
[83.1, "o", "\r\n"]
[85.1, "o", "\u001b[2J\u001b[1;1H"]
[85.3, "o", "\r\n\r\n"]
[85.5, "o", "  \u001b[1;36m\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501 Your Toolkit \u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u001b[0m\r\n"]
[85.9, "o", "\r\n"]
[86.2, "o", "  \u001b[1;37mToday you learned:\u001b[0m\r\n"]
[86.6, "o", "\r\n"]
[86.8, "o", "    \u001b[1;36mpki show\u001b[0m           Inspect any certificate, key, or CSR\r\n"]
[87.3, "o", "    \u001b[1;36mpki show --lint\u001b[0m    Find security issues automatically\r\n"]
[87.8, "o", "    \u001b[1;36mpki diff\u001b[0m           Compare two certificates side by side\r\n"]
[88.3, "o", "    \u001b[1;36mpki dane\u001b[0m           Generate TLSA records for DNS pinning\r\n"]
[88.8, "o", "    \u001b[1;36mpki probe\u001b[0m          Inspect any TLS server live\r\n"]
[89.3, "o", "\r\n"]
[89.7, "o", "  \u001b[1;37mThat's 5 of 19 commands. There's also:\u001b[0m\r\n"]
[90.3, "o", "\r\n"]
[90.5, "o", "    \u001b[0;90mkey gen, csr create, chain build, chain verify,\u001b[0m\r\n"]
[91.1, "o", "    \u001b[0;90mconvert, acme certonly, est enroll, scep enroll...\u001b[0m\r\n"]
[91.7, "o", "\r\n"]
[92.1, "o", "\r\n"]
[92.3, "o", "  \u001b[2m\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u001b[0m\r\n"]
[92.7, "o", "\r\n"]
[92.9, "o", "  \u001b[1;37mThe full QuantumNexum PKI Suite:\u001b[0m\r\n"]
[93.4, "o", "\r\n"]
[93.6, "o", "  \u001b[1;36m\u25b8 PKI-Client\u001b[0m \u2014 what you just used. 19 commands. One binary.\r\n"]
[94.1, "o", "    \u001b[2mPure Rust \u00b7 Post-quantum \u00b7 ACME, EST, SCEP built in\u001b[0m\r\n"]
[94.6, "o", "\r\n"]
[94.8, "o", "  \u001b[1;36m\u25b8 PKI-Signing-Service\u001b[0m \u2014 sign code, documents, timestamps\r\n"]
[95.3, "o", "    \u001b[2mMulti-algorithm \u00b7 Audit logging \u00b7 REST API\u001b[0m\r\n"]
[95.8, "o", "\r\n"]
[96.0, "o", "  \u001b[1;36m\u25b8 PKI-CA-Engine\u001b[0m \u2014 build and operate your own CA\r\n"]
[96.5, "o", "    \u001b[2mDeclarative TOML config \u00b7 Automated issuance \u00b7 Policy enforcement\u001b[0m\r\n"]
