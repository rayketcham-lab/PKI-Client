[70.9, "o", "  \u001b[1;37mDANE TLSA Records\u001b[0m\r\n"]
[71.1, "o", "\r\n"]
[71.3, "o", "  \u001b[2m; Usage 3 (DANE-EE), Selector 1 (SPKI), Matching 1 (SHA-256)\u001b[0m\r\n"]
[71.5, "o", "  \u001b[1;36m_443._tcp.quantumnexum.com.  IN  TLSA  3 1 1  \\\u001b[0m\r\n"]
[71.7, "o", "  \u001b[1;36m    a8f3c2d7e1b9054f6ca3827d4e591b30 \\\u001b[0m\r\n"]
