[76.0, "o", "\u001b[2J\u001b[1;1H"]
[76.2, "o", "\r\n  \u001b[0;90m\u2500\u2500\u2500 Lesson 5: Probing live servers \u2500\u2500\u2500\u001b[0m\r\n\r\n"]
[76.6, "o", "  \u001b[0;90mLast one \u2014 pki probe. Point it at any server.\u001b[0m\r\n"]
[77.2, "o", "\r\n"]
[77.3, "o", "  \u001b[1;32m$\u001b[0m "]
